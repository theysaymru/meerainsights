# Optional — enables the "Ask Meera" AI chat feature (uses the Buildathon Bifrost gateway).
# Without this, the app runs fully on the deterministic engine (AI chat auto-hides).
#
# Local dev:  copy this file to `.env` in the project root and fill in your token,
#             then start the backend (it loads .env automatically).
# Vercel:     add these as Project → Settings → Environment Variables
#             (never commit the real token).
OPENAI_API_KEY=
AI_ENDPOINT=https://gateway-buildathon.ltl.sh/v1/chat/completions
# Available models on the gateway: gpt-4o (default, fast) or gpt-5.5 (max quality)
OPENAI_MODEL=gpt-4o
